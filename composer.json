{
    "name": "mzstack/inkwell-cms",
    "description": "Flat-file CMS and blogging engine powered by Markdown",
    "type": "project",
    "license": "MIT",
    "keywords": ["cms", "blog", "markdown", "flat-file", "static"],
    "homepage": "https://github.com/mzstack/inkwell-cms",
    "authors": [
        {
            "name": "mzstack",
            "homepage": "https://github.com/mzstack"
        }
    ],
    "support": {
        "issues": "https://github.com/mzstack/inkwell-cms/issues",
        "source": "https://github.com/mzstack/inkwell-cms"
    },
    "require": {
        "php": "^8.4",
        "php-di/php-di": "^7.1",
        "symfony/error-handler": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/routing": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "MzStack\\InkwellCms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MzStack\\InkwellCms\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "phpstan": "phpstan analyse",
        "cs-check": "phpcs --standard=PSR12 src tests",
        "cs-fix": "phpcbf --standard=PSR12 src tests"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9",
        "squizlabs/php_codesniffer": "^4.0"
    }
}
