{% set full_url = post.url starts with 'http' ? post.url : (website.url|default('')) ~ post.url %}
{% set text_q   = post.title|url_encode %}
{% set url_q    = full_url|url_encode %}

<div class="post-share">
  <span class="lbl">Share</span>

  <a href="https://mastodon.social/share?text={{ text_q }}%20{{ url_q }}"
     rel="noopener" target="_blank">Mastodon</a>

  <a href="https://twitter.com/intent/tweet?text={{ text_q }}&url={{ url_q }}"
     rel="noopener" target="_blank">X</a>

  <a href="https://news.ycombinator.com/submitlink?u={{ url_q }}&t={{ text_q }}"
     rel="noopener" target="_blank">Hacker News</a>

  <button type="button" class="copy-link" data-url="{{ full_url }}">Copy link</button>
</div>
